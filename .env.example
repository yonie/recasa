# Required: Path to your photo directory (read-only mount)
PHOTOS_PATH=/path/to/your/photos

# Optional: Port to expose the web UI (default: 8080)
RECASA_PORT=8080

# Optional: Ollama URL for AI captioning (default: http://ollama:11434)
# Set to empty string to disable Ollama integration
OLLAMA_URL=http://ollama:11434

# Optional: Ollama vision model for AI captioning (default: qwen3-vl:30b-a3b-instruct)
OLLAMA_MODEL=qwen3-vl:235b-instruct-cloud

# Optional: Filesystem watch interval in seconds (default: 30)
WATCH_INTERVAL=30

# Optional: Log level (default: info)
LOG_LEVEL=info

# Maximum concurrent photo processing (default: 4)
MAX_CONCURRENT=4

# Processing stages (enable/disable per stage)
ENABLE_EXIF_EXTRACTION=true
ENABLE_GEOCODING=true
ENABLE_THUMBNAILS=true
ENABLE_MOTION_PHOTOS=true
ENABLE_HASHING=true
ENABLE_FACE_DETECTION=true
ENABLE_CAPTIONING=true
